{
  "id": "lazybobcat-generic-content",
  "title": "Lazybobcat - Generic Content",
  "version": "1.0.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "flags": {
    "canUpload": true,
    "hotReload": {
      "extensions": [
        "css",
        "html",
        "hbs",
        "json",
        "webp",
        "png",
        "jpg",
        "jpeg",
        "svg"
      ],
      "paths": ["artwork", "packs"]
    }
  },
  "packs": [
    {
      "name": "journal",
      "label": "Journaux",
      "path": "packs/journal",
      "type": "JournalEntry",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "scenes",
      "label": "Scènes",
      "banner": "modules/lazybobcat-generic-content/artwork/landing/table.webp",
      "path": "packs/scenes",
      "type": "Scene",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "cards",
      "label": "Jeux de cartes",
      "path": "packs/cards",
      "type": "Cards",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "playlists",
      "label": "Playlists",
      "path": "packs/playlists",
      "type": "Playlist",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "tables",
      "label": "Tables aléatoires",
      "path": "packs/tables",
      "type": "RollTable",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "pnj",
      "label": "PNJ",
      "path": "packs/pnj",
      "type": "Actor",
      "system": "pf2e",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "authors": [
    {
      "name": "Lazybobcat",
      "flags": {}
    }
  ],
  "description": "",
  "esmodules": ["lazybobcat-generic-content.js"],
  "styles": ["styles/lazybobcat-generic-content.css"],
  "url": "",
  "manifest": "",
  "download": ""
}
