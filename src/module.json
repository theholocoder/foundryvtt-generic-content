{
  "id": "lazybobcat-generic-content",
  "title": "Lazybobcat - Generic Content",
  "version": "1.5.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "relationships": {
    "requires": [
      {
        "id": "pf2e",
        "type": "system",
        "manifest": "https://github.com/foundryvtt/pf2e/releases/latest/download/system.json",
        "reason": "NPC importer and PF2e actor content"
      }
    ]
  },
  "flags": {
    "canUpload": true,
    "hotReload": {
      "extensions": [
        "css",
        "html",
        "hbs",
        "json",
        "webp",
        "png",
        "jpg",
        "jpeg",
        "svg"
      ],
      "paths": ["artwork", "packs"]
    }
  },
  "authors": [
    {
      "name": "TheHolocoder",
      "url": "https://github.com/theholocoder",
      "flags": {}
    }
  ],
  "description": "This module provides useful content and tools for session preparation and game improvisation in FoundryVTT.",
  "esmodules": ["lazybobcat-generic-content.js"],
  "styles": ["styles/lazybobcat-generic-content.css"],
  "url": "https://github.com/theholocoder/foundryvtt-generic-content",
  "manifest": "",
  "download": "",
  "media": [
    {
      "type": "setup",
      "caption": "Lazybobcat - Generic Content",
      "thumbnail": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "loop": false,
      "flags": {}
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "fr",
      "name": "Français",
      "path": "lang/fr.json"
    }
  ],
  "packs": [
    {
      "name": "journal",
      "label": "Journaux",
      "path": "packs/journal",
      "type": "JournalEntry",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "scenes",
      "label": "Scènes",
      "path": "packs/scenes",
      "type": "Scene",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "cards",
      "label": "Jeux de cartes",
      "path": "packs/cards",
      "type": "Cards",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "playlists",
      "label": "Playlists",
      "path": "packs/playlists",
      "type": "Playlist",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "tables",
      "label": "Tables aléatoires",
      "path": "packs/tables",
      "type": "RollTable",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "pnj",
      "label": "PNJ",
      "path": "packs/pnj",
      "type": "Actor",
      "system": "pf2e",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "macros",
      "label": "Macros",
      "path": "packs/macros",
      "type": "Macro",
      "banner": "modules/lazybobcat-generic-content/artwork/module-cover.webp",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      },
      "system": "pf2e"
    }
  ]
}
